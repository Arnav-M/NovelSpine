{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NovelSpine",
  "version": "1.0.0",
  "identifier": "com.novelspine.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "powershell -ExecutionPolicy Bypass -File scripts/stage-sidecar-internal.ps1",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NovelSpine",
        "width": 1100,
        "height": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "$HOME/**",
            "$DOCUMENT/**",
            "$DOWNLOAD/**",
            "$DESKTOP/**",
            "$TEMP/**",
            "$LOCALDATA/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/novelspine-sidecar"
    ],
    "resources": {
      "resources/ffmpeg/": "ffmpeg/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
