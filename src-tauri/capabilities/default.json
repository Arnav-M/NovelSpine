{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Novelflow",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "shell:default",
    "allow-open-with-app",
    "allow-reveal-in-explorer",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/novelflow-sidecar",
          "sidecar": true,
          "args": ["--port", "8765"]
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "reveal-item",
          "cmd": "explorer",
          "args": [{ "validator": "\\S+" }]
        }
      ]
    }
  ]
}
